# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# For local development with Docker: postgresql://postgres:postgres@localhost:5432/ecommerce_db
DATABASE_URL="postgresql://username:password@localhost:5432/ecommerce_db"

# Database connection pool settings (Optional)
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-here-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
# GITHUB_ID="your-github-client-id"
# GITHUB_SECRET="your-github-client-secret"

# =============================================================================
# PAYMENTS (Stripe)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys for development (pk_test_* and sk_test_*)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Stripe Webhook Secret
# Get this after setting up a webhook endpoint at: https://dashboard.stripe.com/webhooks
# For local testing, use Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================================================
# EMAIL SERVICE (Resend)
# =============================================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@yourdomain.com"

# =============================================================================
# FILE STORAGE (Choose ONE provider)
# =============================================================================

# Option 1: AWS S3
# Get credentials from: https://console.aws.amazon.com/iam/
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_S3_BUCKET_NAME="your-bucket-name"
# AWS_REGION="us-east-1"

# Option 2: Cloudflare R2
# Get credentials from: https://dash.cloudflare.com/
# CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key"
# CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-key"
# CLOUDFLARE_R2_BUCKET_NAME="your-bucket-name"
# CLOUDFLARE_R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# Option 3: Supabase Storage
# Get credentials from: https://app.supabase.com/project/_/settings/api
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Public-facing app settings (NEXT_PUBLIC_* are exposed to the browser)
NEXT_PUBLIC_APP_NAME="E-Commerce Store"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin user email (used for initial setup and admin role assignment)
ADMIN_EMAIL="admin@yourdomain.com"

# Environment mode
NODE_ENV="development"

# =============================================================================
# ANALYTICS & MONITORING (Optional)
# =============================================================================
# Google Analytics
# Get your measurement ID from: https://analytics.google.com/
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="GA_MEASUREMENT_ID"

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS="true"

# =============================================================================
# REDIS CACHE (Optional - for production)
# =============================================================================
# Redis connection string for caching and session storage
# Format: redis://username:password@host:port
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# LOGGING & DEBUGGING (Optional)
# =============================================================================
# Log level: debug, info, warn, error
# LOG_LEVEL="info"

# Enable debug mode (shows detailed error messages)
# DEBUG="false"