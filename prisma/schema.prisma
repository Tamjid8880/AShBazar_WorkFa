generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  accepted
  packed
  on_the_way
  processing
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  cod
  prepaid
}

enum DiscountType {
  fixed
  percentage
}

enum CouponStatus {
  active
  inactive
}

model Category {
  id            String        @id @default(cuid())
  name          String
  image         String
  subCategories SubCategory[]
  products      Product[]
  coupons       CouponCode[]  @relation("CouponCategory")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SubCategory {
  id          String       @id @default(cuid())
  name        String
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brands      Brand[]
  products    Product[]
  coupons     CouponCode[] @relation("CouponSubCategory")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Brand {
  id            String      @id @default(cuid())
  name          String
  subcategoryId String
  subCategory   SubCategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)
  products      Product[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model VariantType {
  id        String    @id @default(cuid())
  name      String
  type      String
  variants  Variant[]
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Variant {
  id              String           @id @default(cuid())
  name            String
  variantTypeId   String
  variantType     VariantType      @relation(fields: [variantTypeId], references: [id], onDelete: Restrict)
  productVariants ProductVariant[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Product {
  id               String           @id @default(cuid())
  name             String
  description      String?
  quantity         Int
  price            Float
  offerPrice       Float?
  weight           Float?           @default(0) // Weight in kg
  proCategoryId    String
  proSubCategoryId String
  proBrandId       String?
  proVariantTypeId String?
  proVariantId     String[]
  images           Json
  category         Category         @relation(fields: [proCategoryId], references: [id], onDelete: Restrict)
  subCategory      SubCategory      @relation(fields: [proSubCategoryId], references: [id], onDelete: Restrict)
  brand            Brand?           @relation(fields: [proBrandId], references: [id], onDelete: SetNull)
  variantType      VariantType?     @relation(fields: [proVariantTypeId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]
  coupons          CouponCode[]     @relation("CouponProduct")
  orderItems       OrderItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model CouponCode {
  id                    String       @id @default(cuid())
  couponCode            String       @unique
  discountType          DiscountType
  discountAmount        Float
  minimumPurchaseAmount Float
  endDate               DateTime
  status                CouponStatus @default(active)
  applicableCategoryId  String?
  applicableSubCatId    String?
  applicableProductId   String?
  applicableCategory    Category?    @relation("CouponCategory", fields: [applicableCategoryId], references: [id], onDelete: SetNull)
  applicableSubCategory SubCategory? @relation("CouponSubCategory", fields: [applicableSubCatId], references: [id], onDelete: SetNull)
  applicableProduct     Product?     @relation("CouponProduct", fields: [applicableProductId], references: [id], onDelete: SetNull)
  orders                Order[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Poster {
  id         String   @id @default(cuid())
  posterName String
  imageUrl   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String?  @unique
  phone     String?
  address   String?
  password  String
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  variantId  String
  price      Float
  offerPrice Float?
  stock      Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model DeliveryCharge {
  id         String @id @default(cuid())
  location   String
  minWeight  Float  @default(0)
  maxWeight  Float  @default(9999)
  charge     Float
}

model Order {
  id            String        @id @default(cuid())
  userID        String
  orderDate     DateTime      @default(now())
  orderStatus   OrderStatus    @default(pending)
  totalPrice    Float
  stockDeducted Boolean       @default(false)
  phone         String?
  street        String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  paymentMethod PaymentMethod
  couponCodeId  String?
  subtotal      Float?
  discount      Float?
  deliveryCharge Float?
  total         Float?
  trackingUrl   String?
  user          User          @relation(fields: [userID], references: [id], onDelete: Restrict)
  couponCode    CouponCode?   @relation(fields: [couponCodeId], references: [id], onDelete: SetNull)
  items         OrderItem[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productID   String
  productName String
  quantity    Int
  price       Float
  variant     String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productID], references: [id], onDelete: Restrict)
}

model Notification {
  id             String   @id @default(cuid())
  notificationId String   @unique
  title          String
  description    String
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
