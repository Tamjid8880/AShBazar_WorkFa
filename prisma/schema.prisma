generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  accepted
  packed
  on_the_way
  processing
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  cod
  prepaid
}

enum DiscountType {
  fixed
  percentage
}

enum CouponStatus {
  active
  inactive
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  image         String
  subCategories SubCategory[]
  products      Product[]
  coupons       CouponCode[]  @relation("CouponCategory")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SubCategory {
  id          String       @id @default(cuid())
  name        String
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brands      Brand[]
  products    Product[]
  coupons     CouponCode[] @relation("CouponSubCategory")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, categoryId])
}

model Brand {
  id            String       @id @default(cuid())
  name          String       @unique
  subcategoryId String?
  subCategory   SubCategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  products      Product[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model VariantType {
  id        String    @id @default(cuid())
  name      String
  type      String
  variants  Variant[]
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Variant {
  id              String           @id @default(cuid())
  name            String
  variantTypeId   String
  variantType     VariantType      @relation(fields: [variantTypeId], references: [id], onDelete: Restrict)
  productVariants ProductVariant[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Product {
  id               String           @id @default(cuid())
  name             String
  description      String?
  quantity         Int
  price            Float
  offerPrice       Float?
  weight           Float?           @default(0) // Weight in kg
  proCategoryId    String
  proSubCategoryId String
  proBrandId       String?
  proVariantTypeId String?
  proVariantId     String[]
  images           Json
  isHotDeal        Boolean          @default(false)
  isSpecialOffer   Boolean          @default(false)
  isHidden         Boolean          @default(false)
  category         Category         @relation(fields: [proCategoryId], references: [id], onDelete: Restrict)
  subCategory      SubCategory      @relation(fields: [proSubCategoryId], references: [id], onDelete: Restrict)
  brand            Brand?           @relation(fields: [proBrandId], references: [id], onDelete: SetNull)
  variantType      VariantType?     @relation(fields: [proVariantTypeId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]
  coupons          CouponCode[]     @relation("CouponProduct")
  orderItems       OrderItem[]
  reviews          Review[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model CouponCode {
  id                    String       @id @default(cuid())
  couponCode            String       @unique
  discountType          DiscountType
  discountAmount        Float
  minimumPurchaseAmount Float
  endDate               DateTime
  status                CouponStatus @default(active)
  applicableCategoryId  String?
  applicableSubCatId    String?
  applicableProductId   String?
  applicableCategory    Category?    @relation("CouponCategory", fields: [applicableCategoryId], references: [id], onDelete: SetNull)
  applicableSubCategory SubCategory? @relation("CouponSubCategory", fields: [applicableSubCatId], references: [id], onDelete: SetNull)
  applicableProduct     Product?     @relation("CouponProduct", fields: [applicableProductId], references: [id], onDelete: SetNull)
  orders                Order[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Poster {
  id         String   @id @default(cuid())
  posterName String
  imageUrl   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?  @unique
  address   String?
  division  String?
  district  String?
  upazila   String?
  union     String?
  password  String?
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  orders    Order[]
  reviews   Review[]
  complaints Complaint[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String 
  variantId  String
  price      Float
  offerPrice Float?
  stock      Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model DeliveryCharge {
  id         String @id @default(cuid())
  location   String
  minWeight  Float  @default(0)
  maxWeight  Float  @default(9999)
  charge     Float
}

// ── Shipping Zone System ──────────────────────────────────────────────────────

model ShippingZone {
  id        String           @id @default(cuid())
  name      String           @unique
  status    String           @default("active") // active | inactive
  countries ShippingZoneCountry[]
  methods   ShippingMethod[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ShippingZoneCountry {
  id      String       @id @default(cuid())
  zoneId  String
  country String
  zone    ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, country])
}

model ShippingMethod {
  id              String       @id @default(cuid())
  name            String
  zoneId          String
  status          String       @default("enabled") // enabled | disabled
  calculationType String       // flat_rate | price_based | weight_based | api_based
  zone            ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  flatRate        FlatRate?
  rates           ShippingRate[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([name, zoneId])
}

model FlatRate {
  id       String         @id @default(cuid())
  methodId String         @unique
  cost     Float
  method   ShippingMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
}

model ShippingRate {
  id       String         @id @default(cuid())
  methodId String
  minValue Float          // min price or min weight
  cost     Float
  method   ShippingMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
}

model Order {
  id            String        @id @default(cuid())
  userID        String
  orderDate     DateTime      @default(now())
  orderStatus   OrderStatus    @default(pending)
  totalPrice    Float
  stockDeducted Boolean       @default(false)
  phone         String?
  street        String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  division      String?
  district      String?
  upazila       String?
  union         String?
  paymentMethod PaymentMethod
  couponCodeId  String?
  subtotal      Float?
  discount      Float?
  deliveryCharge Float?
  total         Float?
  trackingUrl   String?
  adminNotes    String?       @db.Text
  user          User          @relation(fields: [userID], references: [id], onDelete: Restrict)
  couponCode    CouponCode?   @relation(fields: [couponCodeId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   @db.Text
  targetId    String?  // e.g. order Id
  targetType  String?  // e.g. 'Order', 'Invoice'
  performedBy String   // admin name/email
  createdAt   DateTime @default(now())
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "customer", "admin", "super_admin"
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime @default(now())
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // "manage_users", "manage_orders", etc
  group       String   @default("general") // "products", "orders", "users", etc
  roles       RolePermission[]
  createdAt   DateTime @default(now())
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productID   String
  productName String
  quantity    Int
  price       Float
  variant     String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productID], references: [id], onDelete: Restrict)
}

model Notification {
  id             String   @id @default(cuid())
  notificationId String   @unique
  title          String
  description    String
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      @default(5)
  comment   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Complaint {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  userId      String
  subject     String
  description String
  status      String   @default("open")
  adminReply  String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  message     String?
  dispatchId  String?
  createdAt   DateTime    @default(now())
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StoreSetting {
  id      String  @id @default("default")
  logoUrl String?
}
