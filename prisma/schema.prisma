generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  image         String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  coupons       CouponCode[]  @relation("CouponCategory")
  products      Product[]
  subCategories SubCategory[]
}

model SubCategory {
  id         String       @id @default(cuid())
  name       String
  categoryId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  brands     Brand[]
  coupons    CouponCode[] @relation("CouponSubCategory")
  products   Product[]
  category   Category     @relation(fields: [categoryId], references: [id])

  @@unique([name, categoryId])
}

model Brand {
  id            String       @id @default(cuid())
  name          String       @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  subcategoryId String?
  subCategory   SubCategory? @relation(fields: [subcategoryId], references: [id])
  products      Product[]
}

model VariantType {
  id        String    @id @default(cuid())
  name      String
  type      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  variants  Variant[]
}

model Variant {
  id              String           @id @default(cuid())
  name            String
  variantTypeId   String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  productVariants ProductVariant[]
  variantType     VariantType      @relation(fields: [variantTypeId], references: [id])
}

model Product {
  id               String           @id @default(cuid())
  name             String
  description      String?
  quantity         Int
  price            Float
  offerPrice       Float?
  proCategoryId    String
  proSubCategoryId String
  proBrandId       String?
  proVariantTypeId String?
  proVariantId     String[]
  images           Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  weight           Float?           @default(0)
  isHidden         Boolean          @default(false)
  isHotDeal        Boolean          @default(false)
  isSpecialOffer   Boolean          @default(false)
  coupons          CouponCode[]     @relation("CouponProduct")
  orderItems       OrderItem[]
  brand            Brand?           @relation(fields: [proBrandId], references: [id])
  category         Category         @relation(fields: [proCategoryId], references: [id])
  subCategory      SubCategory      @relation(fields: [proSubCategoryId], references: [id])
  variantType      VariantType?     @relation(fields: [proVariantTypeId], references: [id])
  variants         ProductVariant[]
  reviews          Review[]
}

model CouponCode {
  id                    String       @id @default(cuid())
  couponCode            String       @unique
  discountType          DiscountType
  discountAmount        Float
  minimumPurchaseAmount Float
  endDate               DateTime
  status                CouponStatus @default(active)
  applicableCategoryId  String?
  applicableSubCatId    String?
  applicableProductId   String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  applicableCategory    Category?    @relation("CouponCategory", fields: [applicableCategoryId], references: [id])
  applicableProduct     Product?     @relation("CouponProduct", fields: [applicableProductId], references: [id])
  applicableSubCategory SubCategory? @relation("CouponSubCategory", fields: [applicableSubCatId], references: [id])
  orders                Order[]
}

model Poster {
  id         String   @id @default(cuid())
  posterName String
  imageUrl   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id         String      @id @default(cuid())
  name       String
  password   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  address    String?
  email      String?     @unique
  phone      String?     @unique
  roleId     String?
  district   String?
  division   String?
  union      String?
  upazila    String?
  complaints Complaint[]
  orders     Order[]
  reviews    Review[]
  role       Role?       @relation(fields: [roleId], references: [id])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  variantId  String
  price      Float
  offerPrice Float?
  stock      Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model DeliveryCharge {
  id        String @id @default(cuid())
  location  String
  minWeight Float  @default(0)
  maxWeight Float  @default(9999)
  charge    Float
}

model ShippingZone {
  id        String                @id @default(cuid())
  name      String                @unique
  status    String                @default("active")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  methods   ShippingMethod[]
  countries ShippingZoneCountry[]
}

model ShippingZoneCountry {
  id      String       @id @default(cuid())
  zoneId  String
  country String
  zone    ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, country])
}

model ShippingMethod {
  id              String         @id @default(cuid())
  name            String
  zoneId          String
  status          String         @default("enabled")
  calculationType String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  flatRate        FlatRate?
  zone            ShippingZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  rates           ShippingRate[]

  @@unique([name, zoneId])
}

model FlatRate {
  id       String         @id @default(cuid())
  methodId String         @unique
  cost     Float
  method   ShippingMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
}

model ShippingRate {
  id       String         @id @default(cuid())
  methodId String
  minValue Float
  cost     Float
  method   ShippingMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
}

model Order {
  id             String               @id @default(cuid())
  userID         String
  orderDate      DateTime             @default(now())
  orderStatus    OrderStatus          @default(pending)
  totalPrice     Float
  phone          String?
  street         String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  paymentMethod  PaymentMethod
  couponCodeId   String?
  subtotal       Float?
  discount       Float?
  total          Float?
  trackingUrl    String?
  deliveryCharge Float?
  stockDeducted  Boolean              @default(false)
  adminNotes     String?
  district       String?
  division       String?
  union          String?
  upazila        String?
  couponCode     CouponCode?          @relation(fields: [couponCodeId], references: [id])
  user           User                 @relation(fields: [userID], references: [id])
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  targetId    String?
  targetType  String?
  performedBy String
  createdAt   DateTime @default(now())
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id        String           @id @default(cuid())
  name      String           @unique
  createdAt DateTime         @default(now())
  group     String           @default("general")
  roles     RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productID   String
  productName String
  quantity    Int
  price       Float
  variant     String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productID], references: [id])
}

model Notification {
  id             String   @id @default(cuid())
  notificationId String   @unique
  title          String
  description    String
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      @default(5)
  comment   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Complaint {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  userId      String
  subject     String
  description String
  status      String   @default("open")
  adminReply  String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrderStatusHistory {
  id         String      @id @default(cuid())
  orderId    String
  status     OrderStatus
  message    String?
  dispatchId String?
  createdAt  DateTime    @default(now())
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StoreSetting {
  id                String  @id @default("default")
  logoUrl           String?
  contactAddress    String?
  contactEmail      String?
  contactMapUrl     String?
  contactPhone      String?
  contactTitle      String?
  footerDescription String?
  footerLinks       Json?
  socialLinks       Json?
}

model Widget {
  id          String   @id @default(cuid())
  section     String
  title       String?
  description String?
  imageUrl    String?
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  review    String
  rating    Int      @default(5)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentOption {
  id             String   @id @default(cuid())
  name           String
  accountDetails String?
  instructions   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
  accepted
  packed
  on_the_way
}

enum PaymentMethod {
  cod
  prepaid
}

enum DiscountType {
  fixed
  percentage
}

enum CouponStatus {
  active
  inactive
}
